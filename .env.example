# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA versione o arquivo .env com chaves reais!

# --- Provedor de LLM ---
# Escolha: "openai" ou "gemini"
LLM_PROVIDER=openai

# Chave da API OpenAI (obtenha em https://platform.openai.com)
OPENAI_API_KEY=sk-...

# Chave da API Google Gemini (obtenha em https://aistudio.google.com)
GOOGLE_API_KEY=AIza...

# --- Configurações do modelo ---
# Modelo a usar: "gpt-4o-mini", "gpt-4o", "gemini-1.5-flash", "gemini-1.5-pro"
MODEL_NAME=gpt-4o-mini

# Temperatura do modelo (0 = determinístico, 1 = criativo)
TEMPERATURE=0.0

# --- Configurações de RAG ---
# Diretório onde ficam os documentos para indexação
DOCS_DIR=dados/documentos

# Número de documentos retornados na busca
RAG_TOP_K=3

# --- Configurações de ferramentas externas ---
# Chave da API OpenWeatherMap (para a ferramenta de clima)
OPENWEATHERMAP_API_KEY=...
